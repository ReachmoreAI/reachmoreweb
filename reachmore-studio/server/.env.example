# Copy this file to ".env" and fill in your own values.
# NEVER commit your real .env or share these keys.

# Port the server runs on
PORT=4000

# Secret used to sign session cookies — use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# ---- Stripe (test mode) ----
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
# Publishable key (safe for the browser)
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Webhook signing secret from `stripe listen` or the Dashboard webhook settings
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Optional: pre-created recurring Price IDs (otherwise prices are created inline)
STRIPE_PRICE_START=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# Public base URL (used for Stripe success/cancel redirects)
PUBLIC_URL=http://localhost:4000

# ---- GoDaddy reseller (white-label domains/hosting) ----
# From your GoDaddy Reseller / Developer account → API keys.
# Leave blank to run the storefront with simulated availability.
GODADDY_KEY=
GODADDY_SECRET=
# "ote" = test sandbox, "prod" = live selling
GODADDY_ENV=ote
# Retail markup on wholesale price (1.4 = +40%)
GODADDY_MARKUP=1.4

# Your Stripe account id (not secret, just for reference)
STRIPE_ACCOUNT_ID=acct_1SABB2KIlLSO8vpt

# First admin (seeded on first run if the DB is empty)
ADMIN_NAME=Marcus
ADMIN_EMAIL=marcushnn21@gmail.com
ADMIN_PASSWORD=mivs1232
